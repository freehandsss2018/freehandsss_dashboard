# Supabase Connection — FHS Dual-System Setup
# Copy this to .env and fill in values from your Supabase project dashboard
# Supabase Dashboard: https://supabase.com/dashboard/project/YOUR_PROJECT_ID/settings/api
#
# SECURITY: Never commit .env to git. Confirm .gitignore includes .env

# Project URL (from API Settings page)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co

# Anon/Public key — safe for Dashboard frontend (read-only via RLS)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Service Role key — n8n only, NEVER expose to frontend
# Bypasses RLS — keep this secret
SUPABASE_SERVICE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Direct Postgres connection string (for migration scripts)
# Format: postgresql://postgres:[YOUR-PASSWORD]@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_ID.supabase.co:5432/postgres
