      "id": "a1b2c3d4-0002-0002-0002-000000000002",
      "name": "Supabase v_delivery_reminders",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [220, 0]
    },
    {
      "parameters": {
        "jsCode": "// NAS-safe: 純 array 操作，無 fetch / process.env / require\nconst items = $input.all();\n\nif (items.length === 0) {\n    return [{ json: { count: 0, text: '' } }];\n}\n\nconst rows = items.map(function(i){ return i.json; });\nconst today = new Date().toLocaleDateString('zh-HK', { timeZone: 'Asia/Hong_Kong' });\n\nvar red    = rows.filter(function(r){ return r.urgency === 'overdue' || r.urgency === 'due_today'; });\nvar yellow = rows.filter(function(r){ return r.urgency === 'warn'; });\n\nvar text = '🚚 FHS 交貨期預警\\n' + today + '\\n';\n\nif (red.length > 0) {\n    text += '\\n🔴 逾期/今日到期 (' + red.length + '):\\n';\n    text += red.map(function(r){\n        var d = Math.abs(Number(r.days_remaining));\n        var status = r.urgency === 'overdue' ? '逾期' + d + '天' : '今日到期';\n        return '• ' + (r.order_id || '—') + ' ' + (r.customer_name || '') + ' (' + status + ')';\n    }).join('\\n');\n}\n\nif (yellow.length > 0) {\n    text += '\\n\\n⚠️ 14天內到期 (' + yellow.length + '):\\n';\n    text += yellow.map(function(r){\n        return '• ' + (r.order_id || '—') + ' ' + (r.customer_name || '') + ' (剩' + r.days_remaining + '天)';\n    }).join('\\n');\n}\n\nreturn [{ json: { count: rows.length, text: text.trim() } }];\n"
      },
