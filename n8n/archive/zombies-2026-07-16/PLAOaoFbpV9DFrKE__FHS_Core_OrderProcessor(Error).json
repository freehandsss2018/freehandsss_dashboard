    {
      "parameters": {
        "jsCode": "\nconst items = $input.all();\nconst skus = [...new Set(items.map(i => i.json.Search_SKU).filter(s => s && s !== \"無\"))];\nconst formulaParts = skus.map(s => `TRIM({Product_Name}) = \"${s}\"`);\nconst finalFormula = skus.length > 1 ? `OR(${formulaParts.join(',')})` : (formulaParts[0] || \"RECORD_ID()='INVALID'\");\nreturn { json: { batchFormula: finalFormula } };\n"
      },
