    {
      "parameters": {
        "jsCode": "\nconst body = ($json.body && $json.body.Order_ID) ? $json.body : ($json.Order_ID ? $json : ($json.body || $json));\nconst orderId = (body.Order_ID || \"未獲取單號\").toString().trim();\nconst customer = body.Customer_Name || \"未獲取客戶名\";\nconst rawAction = body.Action || body.action || \"create\";\nconst action = rawAction.toString().toLowerCase();\nconst revenue = Number(body.System_Final_Sale_Price || body.Final_Sale_Price || (Number(body.Deposit||0) + Number(body.Balance||0) + Number(body.Additional_Fee||0) + Number(body.Adjustment_Amount||0)));\n\n// Restore ALL missing payload fields!\nconst deposit = Number(body.Deposit || 0);\nconst balance = Number(body.Balance || 0);\nconst additionalFee = Number(body.Additional_Fee || Number(body.System_Additional_Fee) || 0);\nconst adjustmentAmount = Number(body.Adjustment_Amount || 0);\nconst rawFormState = body.Raw_Form_State || \"\";\nconst processStatus = body.Process_Status || \"\";\n\nlet outputItems = [];\nconst itemList = body.Order_Items_List || [];\nif (itemList.length === 0) {\n    outputItems.push({\n        json: {\n            Action: action, Order_ID: orderId, Customer_Name: customer, \n            App_Date: body.Appointment_Date || null, Full_Text: body.Full_Order_Text || \"\",\n            Total_Revenue: revenue, Product_Name: \"手動輸入\", Search_SKU: \"\", Qty: 1,\n            Deposit: deposit, Balance: balance, Additional_Fee: additionalFee,\n            Adjustment_Amount: adjustmentAmount, Raw_Form_State: rawFormState, Process_Status: processStatus\n        }\n    });\n} else {\n    itemList.forEach(item => {\n        let name = item.Product_Name || \"\";\n        let mode = item.Production_Mode || \"\";\n        let sku = `${name} ${mode}`.trim();\n        if (name.includes(\"客製化\")) sku = \"客製化 1\";\n        if (name.includes(\"立體擺設\")) sku = `${item.Product_Style || \"\"} ${item.Product_Theme || \"\"} ${item.Limb_Count || \"\"}`.trim().replace(/\\s+/g, ' ');\n        \n        outputItems.push({\n            json: {\n                Action: action, Order_ID: orderId, Customer_Name: customer, \n                App_Date: body.Appointment_Date || null, Full_Text: body.Full_Order_Text || \"\",\n                Total_Revenue: revenue, Product_Name: name, Search_SKU: sku, \n                Qty: Number(item.Quantity) || 1,\n                Deposit: deposit, Balance: balance, Additional_Fee: additionalFee,\n                Adjustment_Amount: adjustmentAmount, Raw_Form_State: rawFormState, Process_Status: processStatus\n            }\n        });\n    });\n}\nreturn outputItems;\n"
      },
