    {
      "parameters": {
        "jsCode": "\nconst items = $('Parse Items').all();\nconst costData = $('Fetch Cost').all();\nconst meta = items[0].json;\n\nlet totalCost = 0;\nitems.forEach(it => {\n    const match = costData.find(c => (c.json.fields?.Product_Name || c.json.Product_Name) === it.json.Search_SKU);\n    const base = Number(match ? (match.json.fields?.Total_Base_Cost || match.json.Total_Base_Cost) : 0) || 0;\n    totalCost += (base * it.json.Qty);\n});\n\nconst profit = meta.Total_Revenue - totalCost;\nconst actLabel = meta.Action === \"update\" ? \"📝 【訂單已修改】\" : \"🆕 【新開單】\";\nconst text = actLabel + \"\\n\" + (meta.Full_Text || \"\") + \"\\n\\n💰 【內部戰報】\\n👤 客人：\" + meta.Customer_Name + \"\\n📝 單號：\" + meta.Order_ID + \"\\n總成本：$\" + totalCost + \"\\n🏆 淨利潤：$\" + profit;\n\nreturn [{ json: { ...meta, Total_Cost: totalCost, Final_Profit: profit, Updated_Text: text } }];\n"
      },
