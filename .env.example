# FHS Environment Variables Template
# Copy this file to .env and fill in real values
# NEVER commit .env to git

# Notion
NOTION_API_KEY=ntn_your_new_key_here
NOTION_DATABASE_ID=329574ef-3b8b-8135-80be-f248aedb9d46

# n8n
N8N_KEY=your_n8n_api_key_here
N8N_INSTANCE=https://yanhei.synology.me:8443

# Airtable (Personal Access Token — 用於 PRICE_AUDIT 空白售價稽核)
# 取得方式: https://airtable.com/create/tokens
AIRTABLE_API_KEY=patXXXXXXXXXXXXXX

# /cl-flow Runner — A2 Gemini 模型配置
# 可用模型清單：gemini-3.5-flash / gemini-3.1-pro-preview（probe 驗證後填入）
PERPLEXITY_API_KEY=pplx-your_key_here
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_A2_MODEL_DEFAULT=gemini-3.5-flash
